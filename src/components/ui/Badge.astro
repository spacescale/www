---
interface Props {
  href?: string;
  icon?: "status";
  ariaLabel?: string;
  size?: "default" | "compact";
  class?: string;
}

const props: Props = Astro.props;
const { href, icon, ariaLabel, size = "default" } = props;
---

{
  href ? (
    <a
      class:list={["badge", `badge--${size}`, props.class]}
      href={href}
      aria-label={ariaLabel}
    >
      {icon === "status" && (
        <span class="badge__status-icon" aria-hidden="true" />
      )}
      {icon !== "status" && <slot name="icon" />}
      <span class="badge__content">
        <slot />
      </span>
    </a>
  ) : (
    <span
      class:list={["badge", `badge--${size}`, props.class]}
      aria-label={ariaLabel}
    >
      {icon === "status" && (
        <span class="badge__status-icon" aria-hidden="true" />
      )}
      {icon !== "status" && <slot name="icon" />}
      <span class="badge__content">
        <slot />
      </span>
    </span>
  )
}

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;

    min-height: 32px;
    margin: 0;
    padding: 5px 14px;

    border: 1px solid #262b33;
    background: transparent;
    color: #8c94a1;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    line-height: 20px;
    text-decoration: none;
  }

  .badge--compact {
    min-height: 30px;
    padding: 4px 8px;
  }

  a.badge {
    transition:
      background-color var(--motion-fast),
      border-color var(--motion-fast),
      color var(--motion-fast);
  }

  a.badge:hover {
    border-color: #343a45;
    background: var(--color-surface-hover);
    color: var(--color-text-hover);
  }

  a.badge:focus-visible {
    outline: 1px solid var(--color-accent-mint);
    outline-offset: 3px;
  }

  .badge__status-icon {
    width: 8px;
    height: 8px;
    flex-shrink: 0;

    border-radius: 999px;
    background: var(--color-accent-mint);
    animation: badge-status-dot-pulse 1800ms ease-in-out infinite;
  }

  .badge__content {
    min-width: 0;
  }

  @keyframes badge-status-dot-pulse {
    0%,
    100% {
      opacity: 0.78;
      transform: scale(1);
    }

    50% {
      opacity: 1;
      transform: scale(1.16);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge__status-icon {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .badge:not(.badge--compact) {
      padding: 7px 10px;
      font-size: 12px;
      line-height: 18px;
    }
  }
</style>
