---
const igniteChips = [
    "High-performance workloads",
    "Long-running services",
];

const machineChips = [
    "Agent workspaces",
    "Sandboxes",
    "Preview environments",
];
---

<section class="execution-surfaces" aria-labelledby="execution-surfaces-title">
    <div class="execution-surfaces__inner">
        <h2 id="execution-surfaces-title" class="execution-surfaces__title">
            <span>One foundation. </span><span>Two execution surfaces.</span>
        </h2>

        <div class="execution-surfaces__card" data-node-id="1286:2763">
            <div class="execution-surfaces__divider" aria-hidden="true"></div>

            <article class="execution-surfaces__surface execution-surfaces__surface--ignite">
                <div class="execution-surfaces__icon" aria-hidden="true">
                    <img
                        src="/assets/execution-surfaces/ignite-microvm.svg"
                        alt=""
                        width="72"
                        height="72"
                        loading="lazy"
                    />
                </div>

                <div class="execution-surfaces__copy">
                    <h3>Ignite</h3>
                    <p>
                        Ignite runs services in microVMs. Bring an OCI image.
                        SpaceScale starts it, routes it, observes it, and manages the
                        runtime underneath.
                    </p>
                    <p class="execution-surfaces__label">Good for:</p>
                    <ul class="execution-surfaces__chips" aria-label="Ignite use cases">
                        {igniteChips.map((chip) => <li>{chip}</li>)}
                    </ul>
                </div>
            </article>

            <article class="execution-surfaces__surface execution-surfaces__surface--machines">
                <div class="execution-surfaces__icon" aria-hidden="true">
                    <img
                        src="/assets/execution-surfaces/machines-chip.svg"
                        alt=""
                        width="72"
                        height="72"
                        loading="lazy"
                    />
                </div>

                <div class="execution-surfaces__copy">
                    <h3>Machines</h3>
                    <p>
                        An isolated ready workspace where AI agents can work, run tasks,
                        keep state, expose results, and hand work back to humans.
                    </p>
                    <p class="execution-surfaces__label">Good for:</p>
                    <ul class="execution-surfaces__chips" aria-label="Machines use cases">
                        {machineChips.map((chip) => <li>{chip}</li>)}
                    </ul>
                </div>
            </article>
        </div>
    </div>
</section>

<style>
    .execution-surfaces {
        padding: 80px var(--site-padding-x);
        background: #040406;
    }

    .execution-surfaces__inner {
        width: 100%;
        max-width: var(--site-max-width);
        margin: 0 auto;
    }

    .execution-surfaces__title {
        width: 900px;
        max-width: 100%;
        margin: 0 auto 80px;
        color: #f5f7fa;
        font-family: var(--font-display);
        font-size: 44px;
        font-weight: 400;
        line-height: 52px;
        letter-spacing: -0.66px;
        text-align: center;
    }

    .execution-surfaces__title span + span {
        color: #8a8f98;
    }

    .execution-surfaces__card {
        position: relative;
        height: 432px;
        overflow: hidden;
        border: 1px solid #262b33;
        background: #040406;
    }

    .execution-surfaces__divider {
        position: absolute;
        top: 0;
        bottom: 0;
        left: var(--execution-surfaces-divider-left, 624px);
        width: 1px;
        background-image: repeating-linear-gradient(
            to bottom,
            #262b33 0,
            #262b33 6px,
            transparent 6px,
            transparent 12px
        );
        pointer-events: none;
    }

    .execution-surfaces__surface {
        position: absolute;
    }

    .execution-surfaces__surface--ignite {
        top: 56px;
        left: var(--execution-surfaces-left-inset, 66px);
        width: var(--execution-surfaces-column-width, 547px);
    }

    .execution-surfaces__surface--machines {
        top: 56px;
        right: var(--execution-surfaces-right-inset, auto);
        left: var(--execution-surfaces-right-left, 704px);
        width: var(--execution-surfaces-column-width, 547px);
    }

    .execution-surfaces__icon {
        width: 72px;
        height: 72px;
    }

    .execution-surfaces__icon img {
        display: block;
        width: 100%;
        height: 100%;
    }

    .execution-surfaces__copy {
        width: 452px;
        max-width: 100%;
        margin-top: 36px;
    }

    .execution-surfaces__surface--machines .execution-surfaces__copy {
        margin-top: 52px;
    }

    .execution-surfaces__copy h3 {
        margin: 0;
        color: #f5f7fa;
        font-family: var(--font-display);
        font-size: 40px;
        font-weight: 400;
        line-height: 40px;
        letter-spacing: -0.4px;
    }

    .execution-surfaces__copy p {
        margin: 16px 0 0;
        color: #8c94a1;
        font-family: var(--font-body);
        font-size: 15px;
        font-weight: 400;
        line-height: 24px;
        letter-spacing: 0;
    }

    .execution-surfaces__copy .execution-surfaces__label {
        margin-top: 16px;
    }

    .execution-surfaces__chips {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        width: 547px;
        max-width: 100%;
        margin: 16px 0 0;
        padding: 0;
        list-style: none;
    }

    .execution-surfaces__chips li {
        display: inline-flex;
        align-items: center;
        min-height: 40px;
        padding: 7px 8px;
        border: 1px solid rgb(255 255 255 / 10%);
        color: #8c94a1;
        font-family: var(--font-body);
        font-size: 15px;
        font-weight: 400;
        line-height: 24px;
        letter-spacing: 0;
        white-space: nowrap;
    }

    @media (max-width: 1440px) {
        .execution-surfaces__card {
            --execution-surfaces-divider-left: 50%;
            --execution-surfaces-left-inset: clamp(48px, 5vw, 66px);
            --execution-surfaces-right-inset: clamp(48px, 5vw, 66px);
            --execution-surfaces-right-left: auto;
            --execution-surfaces-column-width: calc(50% - clamp(64px, 6vw, 80px));
        }

        .execution-surfaces__chips {
            width: 100%;
        }
    }

    @media (max-width: 1180px) and (min-width: 901px) {
        .execution-surfaces__card {
            --execution-surfaces-left-inset: 40px;
            --execution-surfaces-column-width: calc(50% - 88px);
        }

        .execution-surfaces__surface--ignite {
            width: calc(50% - 52px);
        }

        .execution-surfaces__copy {
            width: 100%;
        }

        .execution-surfaces__copy p {
            max-width: 452px;
        }

        .execution-surfaces__surface--machines .execution-surfaces__chips li:nth-child(3) {
            display: none;
        }
    }

    @media (max-width: 1000px) and (min-width: 901px) {
        .execution-surfaces__card {
            --execution-surfaces-left-inset: 32px;
        }

        .execution-surfaces__surface--ignite {
            width: calc(50% - 40px);
        }

        .execution-surfaces__chips {
            gap: 8px;
        }

        .execution-surfaces__chips li {
            padding-right: 6px;
            padding-left: 6px;
            font-size: 14px;
            line-height: 22px;
        }
    }

    @media (max-width: 900px) {
        .execution-surfaces__divider {
            display: none;
        }

        .execution-surfaces__card {
            height: auto;
            overflow: visible;
        }

        .execution-surfaces__surface {
            position: relative;
            top: auto;
            right: auto;
            left: auto;
            width: 100%;
            padding: 48px;
        }

        .execution-surfaces__surface--machines {
            left: auto;
        }

        .execution-surfaces__surface--machines::before {
            position: absolute;
            top: 0;
            right: 0;
            left: 0;
            height: 1px;
            background-image: repeating-linear-gradient(
                to right,
                #262b33 0,
                #262b33 6px,
                transparent 6px,
                transparent 12px
            );
            content: "";
        }

        .execution-surfaces__copy,
        .execution-surfaces__surface--machines .execution-surfaces__copy {
            width: 100%;
            margin-top: 36px;
        }

        .execution-surfaces__chips {
            width: 100%;
        }

        .execution-surfaces {
            padding-top: 64px;
            padding-bottom: 64px;
        }

        .execution-surfaces__title {
            margin-bottom: 56px;
            font-size: 36px;
            line-height: 44px;
        }
    }

    @media (max-width: 640px) {
        .execution-surfaces {
            padding-top: 48px;
            padding-bottom: 48px;
        }

        .execution-surfaces__title {
            margin-bottom: 40px;
            font-size: 30px;
            line-height: 38px;
            letter-spacing: 0;
            text-align: left;
        }

        .execution-surfaces__surface {
            padding: 32px 20px;
        }

        .execution-surfaces__copy h3 {
            font-size: 32px;
            line-height: 36px;
        }

        .execution-surfaces__chips li {
            white-space: normal;
        }
    }
</style>
