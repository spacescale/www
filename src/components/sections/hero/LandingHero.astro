---
import HeroTerminalShell from "./HeroTerminalShell.astro";
import Badge from "../../ui/Badge.astro";
---

<section class="landing-hero" aria-labelledby="landing-hero-title">
    <div class="landing-hero__foundation" data-node-id="1177:601" aria-hidden="true"></div>

    <div class="landing-hero__inner">
        <Badge class="landing-hero__badge" href="/engineering">
            Currently in active development — follow our story
        </Badge>

        <h1 id="landing-hero-title" class="landing-hero__title">
            Infrastructure for<br />
            humans and agents.
        </h1>

        <p class="landing-hero__support" data-node-id="1085:113">
            Deploy isolated container workloads with Ignite. Create persistent Machines
            for humans and agents to use as real workspaces.
        </p>
    </div>

    <HeroTerminalShell />
</section>

<style>
    .landing-hero {
        --landing-hero-padding-top: 40px;
        --landing-hero-padding-bottom: 124px;
        --landing-hero-title-width: 575px;
        --landing-hero-title-size: 64px;
        --landing-hero-title-line-height: 72px;
        --landing-hero-terminal-top: 408px;
        --landing-hero-foundation-top: 846px;
        --landing-hero-foundation-height: 432px;
        --landing-hero-min-height: 1278px;

        position: relative;
        overflow: clip;
        min-height: var(--landing-hero-min-height);
        padding:
            var(--landing-hero-padding-top)
            var(--site-padding-x)
            var(--landing-hero-padding-bottom);
        background: #040406;
    }

    .landing-hero__foundation {
        position: absolute;
        top: var(--landing-hero-foundation-top);
        left: 50%;
        z-index: 0;
        width: 100vw;
        height: var(--landing-hero-foundation-height);
        transform: translateX(-50%);
        background: linear-gradient(180deg, #040406 0%, #737373 100%);
        pointer-events: none;
    }

    .landing-hero__inner {
        width: 100%;
        max-width: var(--site-max-width);
        margin: 0 auto;
    }

    :global(.landing-hero__badge),
    .landing-hero__title,
    .landing-hero__support {
        position: relative;
        z-index: 1;
    }

    .landing-hero__title {
        width: var(--landing-hero-title-width);
        max-width: 100%;
        margin: 32px 0 0;
        color: #f5f7fa;
        font-family: var(--font-display);
        font-size: var(--landing-hero-title-size);
        font-weight: 400;
        line-height: var(--landing-hero-title-line-height);
        letter-spacing: 0;
    }

    .landing-hero__support {
        width: 609px;
        max-width: 100%;
        margin: 32px 0 0;
        color: #8c94a1;
        font-family: var(--font-body);
        font-size: 16px;
        font-weight: 400;
        line-height: 24px;
        letter-spacing: 0;
    }

    @media (max-width: 1180px) {
        .landing-hero {
            --landing-hero-padding-top: 40px;
            --landing-hero-padding-bottom: 112px;
            --landing-hero-title-width: 540px;
            --landing-hero-title-size: 56px;
            --landing-hero-title-line-height: 64px;
            --landing-hero-terminal-top: 408px;
        }
    }

    @media (max-width: 900px) {
        .landing-hero {
            --landing-hero-padding-top: 48px;
            --landing-hero-padding-bottom: 96px;
            --landing-hero-title-size: 48px;
            --landing-hero-title-line-height: 54px;
            --landing-hero-terminal-top: 420px;
        }
    }

    @media (max-width: 640px) {
        .landing-hero {
            --landing-hero-padding-top: 84px;
            --landing-hero-padding-bottom: 88px;
            --landing-hero-title-width: 100%;
            --landing-hero-title-size: 40px;
            --landing-hero-title-line-height: 46px;
            --landing-hero-terminal-top: 460px;
        }

        .landing-hero__title {
            margin-top: 28px;
        }
    }
</style>
