---
interface Props {
    date: string;
    title: string;
    description: string;
    coverImage: string;
    href: string;
    cardVisual?: string;
    transitionName?: string;
    insetText?: boolean;
    rightDivider?: boolean;
    topDivider?: boolean;
    stackedDivider?: boolean;
}

const {
    date,
    title,
    description,
    coverImage,
    href,
    cardVisual,
    transitionName,
    insetText = false,
    rightDivider = false,
    topDivider = false,
    stackedDivider = false,
} = Astro.props;

const cardClass = [
    "engineering-card",
    rightDivider ? "engineering-card--right-divider" : "",
    topDivider ? "engineering-card--top-divider" : "",
    stackedDivider ? "engineering-card--stacked-divider" : "",
]
    .filter(Boolean)
    .join(" ");
const copyClass = insetText
    ? "engineering-card__copy engineering-card__copy--inset"
    : "engineering-card__copy";
---

<article class={cardClass}>
    <a class="engineering-card__image" href={href} aria-label={`Read ${title}`}>
        <img
            class="engineering-card__cover"
            src={coverImage}
            alt=""
            loading="lazy"
            decoding="async"
            data-visual={cardVisual}
        />
    </a>
    <div class={copyClass}>
        <p class="engineering-card__date">{date}</p>
        <h2 class="engineering-card__title" transition:name={transitionName}>
            <a class="engineering-card__title-link" href={href}>{title}</a>
        </h2>
        <p class="engineering-card__description">
            {description}
        </p>
    </div>
</article>

<style>
    .engineering-card {
        display: flex;
        width: 100%;
        height: 495px;
        flex-direction: column;
        gap: 16px;
        align-items: flex-start;
        padding: 24px;
        overflow: clip;
        background: var(--color-bg-primary);
        box-sizing: border-box;
    }

    .engineering-card--right-divider {
        border-right: 1px solid #262b33;
    }

    .engineering-card--top-divider {
        border-top: 1px solid #262b33;
    }

    .engineering-card__image {
        position: relative;
        width: 100%;
        height: 310px;
        flex-shrink: 0;
        color: inherit;
        text-decoration: none;
    }

    .engineering-card__cover {
        position: absolute;
        inset: 0;
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        background: #040406;
        pointer-events: none;
    }

    .engineering-card__copy {
        display: flex;
        width: 100%;
        height: 121px;
        flex-direction: column;
        gap: 8px;
        align-items: flex-start;
        flex-shrink: 0;
        overflow: hidden;
        font-family: var(--font-body);
        font-weight: 400;
        font-style: normal;
        box-sizing: border-box;
    }

    .engineering-card__copy--inset {
        padding-inline: 24px;
    }

    .engineering-card__date,
    .engineering-card__title,
    .engineering-card__description {
        width: 100%;
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 400;
    }

    .engineering-card__title,
    .engineering-card__description {
        display: -webkit-box;
        -webkit-box-orient: vertical;
    }

    .engineering-card__date,
    .engineering-card__description {
        color: #8c94a1;
        font-size: 16px;
        line-height: 23px;
        letter-spacing: -0.08px;
    }

    .engineering-card__description {
        -webkit-line-clamp: 2;
    }

    .engineering-card__title-link {
        color: inherit;
        text-decoration: none;
    }

    .engineering-card__image:focus-visible,
    .engineering-card__title-link:focus-visible {
        outline: 1px solid #66d9a8;
        outline-offset: 4px;
    }

    .engineering-card__title {
        color: #f5f7fa;
        font-size: 24px;
        line-height: 36px;
        letter-spacing: -0.12px;
        -webkit-line-clamp: 2;
    }

    @media (max-width: 1180px) {
        .engineering-card {
            height: auto;
            min-height: 405px;
        }

        .engineering-card__image {
            height: 260px;
        }

        .engineering-card__copy {
            height: auto;
            min-height: 121px;
        }

        .engineering-card__title {
            -webkit-line-clamp: 2;
        }

        .engineering-card__description {
            -webkit-line-clamp: 3;
        }
    }

    @media (max-width: 900px) {
        .engineering-card--right-divider {
            border-right: 0;
        }

        .engineering-card--top-divider {
            border-top: 0;
        }

        .engineering-card--stacked-divider {
            border-top: 1px solid #262b33;
        }
    }

    @media (max-width: 640px) {
        .engineering-card {
            padding: 24px;
        }

        .engineering-card__image {
            height: clamp(168px, 52vw, 220px);
        }

        .engineering-card__copy--inset {
            padding-inline: 0;
        }
    }
</style>
