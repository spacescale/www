---
import PerformanceRow from "./product/PerformanceRow.astro";
import ExecutionIsolationRow from "./product/ExecutionIsolationRow.astro";
import EndpointsRow from "./product/EndpointsRow.astro";
import NetworkMappingRow from "./product/NetworkMappingRow.astro";
---
<section class="product-section" aria-label="SpaceScale product capabilities">
    <div class="product-section__inner">
        <div class="product-section__card" aria-label="SpaceScale product capabilities">
            <div class="product-section__row product-section__row--performance">
                <PerformanceRow />
            </div>
            <div class="product-section__row product-section__row--isolation">
                <ExecutionIsolationRow />
            </div>
            <div class="product-section__row product-section__row--endpoints">
                <EndpointsRow />
            </div>
            <div class="product-section__row product-section__row--container"></div>
            <div class="product-section__row product-section__row--network">
                <NetworkMappingRow />
            </div>
        </div>
    </div>
</section>

<style>
    .product-section {
        --product-section-padding-y: 80px;
        --product-section-card-height: 2992px;
        --product-section-performance-row-height: 592px;
        --product-section-isolation-row-height: 591px;
        --product-section-endpoints-row-height: 700px;
        --product-section-container-row-height: 539px;
        --product-section-network-row-height: 570px;
        --product-section-row-padding: 0;
        --product-section-placeholder-row-height: auto;
        --product-row-tablet-copy-left: 64px;
        --product-row-tablet-copy-width: 330px;
        --product-row-mobile-copy-max-width: 460px;
        --product-row-mobile-visual-gap: 36px;
        --product-row-mobile-visual-gap-tight: 28px;
        --product-row-mobile-heading-size: 24px;
        --product-row-mobile-heading-line-height: 32px;
        --product-row-mobile-body-size: 14px;
        --product-row-mobile-body-line-height: 22px;

        position: relative;
        padding: var(--product-section-padding-y) var(--site-padding-x);
        background: var(--color-bg-primary);
    }

    .product-section::before {
        content: "";
        position: absolute;
        top: var(--product-section-padding-y);
        right: 0;
        left: 0;
        z-index: 2;
        height: 1px;
        background: #262b33;
        pointer-events: none;
    }

    .product-section__inner {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: var(--site-max-width);
        margin: 0 auto;
    }

    .product-section__card {
        position: relative;
        display: grid;
        grid-template-rows:
            var(--product-section-performance-row-height)
            var(--product-section-isolation-row-height)
            var(--product-section-endpoints-row-height)
            var(--product-section-container-row-height)
            var(--product-section-network-row-height);
        width: 100%;
        height: var(--product-section-card-height);
        overflow: clip;
        border: 1px solid #262b33;
        border-top: 0;
        background: var(--color-bg-primary);
    }

    .product-section__row {
        position: relative;
        min-width: 0;
        padding: var(--product-section-row-padding);
    }

    .product-section__row--endpoints {
        z-index: 1;
    }

    .product-section__row + .product-section__row {
        border-top: 1px solid #262b33;
    }

    @media (max-width: 1180px) {
        .product-section {
            --product-section-padding-y: 72px;
            --product-section-card-height: auto;
            --product-section-performance-row-height: 540px;
            --product-section-isolation-row-height: 520px;
            --product-section-endpoints-row-height: 620px;
            --product-section-container-row-height: 300px;
            --product-section-network-row-height: 460px;
        }
    }

    @media (max-width: 900px) {
        .product-section {
            --product-section-padding-y: 64px;
            --product-section-row-padding: 56px 32px;
            --product-section-placeholder-row-height: 220px;
        }

        .product-section__card {
            display: block;
            overflow: visible;
        }

        .product-section__row--container {
            height: var(--product-section-placeholder-row-height);
            padding: 0;
        }
    }

    @media (max-width: 640px) {
        .product-section {
            --product-section-padding-y: 48px;
            --product-section-row-padding: 40px 18px;
            --product-section-placeholder-row-height: 150px;
        }
    }
</style>
