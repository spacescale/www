---
import PerformanceRow from "./product/PerformanceRow.astro";
import ExecutionIsolationRow from "./product/ExecutionIsolationRow.astro";
---
<section class="product-section" aria-label="SpaceScale product capabilities">
    <div class="product-section__inner">
        <div class="product-section__card" aria-label="SpaceScale product capabilities">
            <div class="product-section__row product-section__row--performance">
                <PerformanceRow />
            </div>
            <div class="product-section__row product-section__row--isolation">
                <ExecutionIsolationRow />
            </div>
            <div class="product-section__row product-section__row--container"></div>
            <div class="product-section__row product-section__row--endpoints"></div>
            <div class="product-section__row product-section__row--network"></div>
        </div>
    </div>
</section>

<style>
    .product-section {
        position: relative;
        padding: 80px var(--site-padding-x);
        background: var(--color-bg-primary);
    }

    .product-section::before {
        content: "";
        position: absolute;
        top: 80px;
        right: 0;
        left: 0;
        z-index: 2;
        height: 1px;
        background: #262b33;
        pointer-events: none;
    }

    .product-section__inner {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: var(--site-max-width);
        margin: 0 auto;
    }

    .product-section__card {
        position: relative;
        display: grid;
        grid-template-rows: 592px 591px 549px 690px 570px;
        width: 100%;
        height: 2992px;
        overflow: clip;
        border: 1px solid #262b33;
        border-top: 0;
        background: var(--color-bg-primary);
    }

    .product-section__row {
        position: relative;
        min-width: 0;
    }

    .product-section__row + .product-section__row {
        border-top: 1px solid #262b33;
    }
</style>
