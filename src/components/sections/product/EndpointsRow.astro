<div class="endpoints-copy">
    <h2>We provide the endpoints,<br />you dictate the scale.</h2>
    <p>
        Bypass the dashboard and control our execution engine via REST API. Ignite
        and terminate workloads at lightning speed. Designed for high-frequency AI
        agents and programmatic fleet routing.
    </p>
</div>

<figure class="endpoints-curl" aria-label="Example SpaceScale API request">
    <figcaption>
        <span>Example request</span>
        <button
            class="endpoints-curl__copy"
            type="button"
            aria-label="Copy example request"
            data-endpoints-copy
        >
            <svg viewBox="0 0 16 16" focusable="false">
                <path
                    d="M5 2.5h6.5a2 2 0 0 1 2 2V11H12V4.5a.5.5 0 0 0-.5-.5H5V2.5Z"
                ></path>
                <path
                    d="M2.5 5A1.5 1.5 0 0 1 4 3.5h6A1.5 1.5 0 0 1 11.5 5v6A1.5 1.5 0 0 1 10 12.5H4A1.5 1.5 0 0 1 2.5 11V5Zm1.5 0v6h6V5H4Z"
                ></path>
            </svg>
            <span data-copy-label>Copy</span>
        </button>
    </figcaption>

    <pre><code><span class="code-primary">curl -X POST https://api.spacescale.io/v1/ignite \</span>
  -H "Authorization: Bearer sk_live_..." \
  -H "Content-Type: application/json" \
  -d '&#123;
<span class="code-primary">    "image": "my-org/trading-api:latest",</span>
<span class="code-accent">    "regions": ["ca-east"],</span>
  &#125;'</code></pre>
</figure>

<div class="endpoints-visual" aria-hidden="true">
    <img
        class="endpoints-visual__asset"
        src="/assets/product/endpoint-wrap.svg"
        alt=""
    />
</div>

<script>
    const copyTextToClipboard = async (text: string) => {
        await navigator.clipboard.writeText(text);
    };

    document.querySelectorAll("[data-endpoints-copy]").forEach((button) => {
        button.addEventListener("click", async () => {
            const code = button
                .closest(".endpoints-curl")
                ?.querySelector("code")
                ?.textContent?.trimEnd();
            const label = button.querySelector("[data-copy-label]");

            if (!code || !label) {
                return;
            }

            try {
                await copyTextToClipboard(code);
                label.textContent = "Copied";
            } catch {
                label.textContent = "Copy";
                return;
            }

            window.setTimeout(() => {
                label.textContent = "Copy";
            }, 1400);
        });
    });
</script>

