---
import NetworkMappingDiagram from "./NetworkMappingDiagram.astro";
---

<div class="network-mapping-copy">
    <h2>Automatic Network Mapping</h2>
    <p>
        Our intelligent router detects exposed ports and maps each service to the
        right network path. Public services get TLS, DNS, and load balancing.
        Private services stay isolated on the internal mesh.
    </p>
</div>

<div class="network-mapping-visual" aria-hidden="true">
    <NetworkMappingDiagram />
</div>

<style>
    .network-mapping-copy {
        --network-mapping-copy-tablet-top: 54px;

        position: absolute;
        top: 54px;
        left: 97px;
        width: 389px;
    }

    .network-mapping-copy h2 {
        margin: 0;
        color: #f5f7fa;
        font-family: var(--font-body);
        font-size: 28px;
        font-weight: 400;
        line-height: 36px;
        letter-spacing: -0.28px;
    }

    .network-mapping-copy p {
        margin: 16px 0 0;
        color: #8c94a1;
        font-family: var(--font-body);
        font-size: 15px;
        font-weight: 400;
        line-height: 24px;
    }

    .network-mapping-visual {
        --network-mapping-visual-tablet-right: 32px;
        --network-mapping-diagram-scale: 1;

        position: absolute;
        top: 26px;
        right: 48px;
        width: 620px;
        height: 500px;
        overflow: clip;
        user-select: none;
    }

    @media (max-width: 1180px) {
        .network-mapping-copy {
            top: var(--network-mapping-copy-tablet-top);
            left: var(--product-row-tablet-copy-left);
            width: var(--product-row-tablet-copy-width);
        }

        .network-mapping-visual {
            right: var(--network-mapping-visual-tablet-right);
            width: 560px;
        }

        .network-mapping-visual :global(.network-diagram) {
            transform: scale(0.9);
            transform-origin: top right;
        }
    }

    @media (max-width: 900px) {
        .network-mapping-copy {
            position: relative;
            top: auto;
            left: auto;
            width: 100%;
            max-width: var(--product-row-mobile-copy-max-width);
        }

        .network-mapping-visual {
            position: relative;
            top: auto;
            right: auto;
            display: flex;
            width: 100%;
            height: 500px;
            justify-content: center;
            margin-top: var(--product-row-mobile-visual-gap);
            overflow: clip;
        }

        .network-mapping-visual :global(.network-diagram) {
            transform: scale(1);
            transform-origin: top center;
        }
    }

    @media (max-width: 640px) {
        .network-mapping-copy h2 {
            font-size: var(--product-row-mobile-heading-size);
            line-height: var(--product-row-mobile-heading-line-height);
            letter-spacing: 0;
        }

        .network-mapping-copy p {
            font-size: var(--product-row-mobile-body-size);
            line-height: var(--product-row-mobile-body-line-height);
        }

        .network-mapping-visual {
            height: 320px;
            margin-top: var(--product-row-mobile-visual-gap-tight);
        }

        .network-mapping-visual :global(.network-diagram) {
            transform: scale(0.64);
        }
    }

    @media (max-width: 430px) {
        .network-mapping-visual {
            height: 280px;
        }

        .network-mapping-visual :global(.network-diagram) {
            transform: scale(0.56);
        }
    }

</style>
