<style>
    .push-once {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 80px;
        min-height: 576px;
        padding: 120px var(--site-padding-x);
        overflow: clip;
        background: var(--color-bg-primary);
    }

    .push-once__intro {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        text-align: center;
    }

    .push-once__eyebrow {
        margin: 0;
        color: #66d9b2;
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 500;
        line-height: normal;
        letter-spacing: 1.04px;
    }

    .push-once__title {
        width: min(900px, 100%);
        margin: 0;
        color: #f5f7fa;
        font-family: var(--font-display);
        font-size: 44px;
        font-weight: 400;
        line-height: 52px;
        letter-spacing: 0;
        text-align: center;
    }

    .push-once__title span {
        color: #8a8f98;
    }

    .push-once__features {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 32px;
        width: min(1170px, 100%);
    }

    .push-once__feature {
        --push-once-rule-height: 146px;
        --push-once-rule-active-height: 35.755px;

        display: grid;
        grid-template-columns: 2px minmax(0, 1fr);
        align-items: start;
        gap: 12px;
        min-width: 0;
    }

    .push-once__feature--routing {
        --push-once-rule-height: 168px;
        --push-once-rule-active-height: 28.394px;
    }

    .push-once__feature--rollouts {
        --push-once-rule-active-height: 24.676px;
    }

    .push-once__rule {
        position: relative;
        width: 2px;
        height: var(--push-once-rule-height);
        background: #262b33;
    }

    .push-once__rule::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 2px;
        height: var(--push-once-rule-active-height);
        background: #ffffff;
    }

    .push-once__feature-copy {
        display: flex;
        width: min(360px, 100%);
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
        min-width: 0;
    }

    .push-once__icon {
        display: block;
        width: 32px;
        height: 32px;
        flex: 0 0 auto;
        color: var(--color-accent-mint);
    }

    .push-once__icon path {
        fill: currentColor;
    }

    .push-once__text {
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-width: 0;
        font-family: var(--font-body);
    }

    .push-once__text h3 {
        margin: 0;
        color: #f5f7fa;
        font-size: 20px;
        font-weight: 400;
        line-height: normal;
    }

    .push-once__text p {
        margin: 0;
        color: #8c94a1;
        font-size: 16px;
        font-weight: 400;
        line-height: 22px;
    }

    @media (max-width: 1180px) {
        .push-once {
            gap: 72px;
            min-height: 0;
            padding-block: 96px;
        }

        .push-once__features {
            gap: 24px;
        }
    }

    @media (max-width: 900px) {
        .push-once {
            gap: 56px;
            padding-block: 80px;
        }

        .push-once__title {
            font-size: 40px;
            line-height: 48px;
        }

        .push-once__features {
            grid-template-columns: 1fr;
            gap: 32px;
            max-width: 560px;
        }

        .push-once__feature-copy {
            width: 100%;
        }
    }

    @media (max-width: 640px) {
        .push-once {
            gap: 44px;
            padding-block: 64px;
        }

        .push-once__eyebrow {
            font-size: 12px;
            letter-spacing: 0.96px;
        }

        .push-once__title {
            font-size: 32px;
            line-height: 40px;
        }

        .push-once__text h3 {
            font-size: 19px;
        }

        .push-once__text p {
            font-size: 15px;
            line-height: 22px;
        }
    }
</style>
