---
interface Props {
    date: string;
    title: string;
    href: string;
    category?: string;
}

const { date, title, href, category } = Astro.props;
---

<article class="blog-card">
    <a class="blog-card__link" href={href}>
        <div class="blog-card__body">
            <h2 class="blog-card__title">{title}</h2>
            <p class="blog-card__date">
                <span class="blog-card__tree">└─</span>
                {date}
            </p>
        </div>
        <span class="blog-card__category">{category}</span>
    </a>
</article>

<style>
    .blog-card {
        width: 100%;
        border-bottom: 1px solid #262b33;
        box-sizing: border-box;
    }

    .blog-card__link {
        display: flex;
        width: 100%;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 16px 24px;
        color: inherit;
        text-decoration: none;
    }

    .blog-card__link:hover .blog-card__title {
        opacity: 0.7;
    }

    .blog-card__link:focus-visible {
        outline: 1px solid #66d9a8;
        outline-offset: 4px;
    }

    .blog-card__body {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .blog-card__title {
        margin: 0;
        color: #f5f7fa;
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 400;
        line-height: 28px;
        letter-spacing: -0.2px;
        transition: opacity 0.15s ease;
    }

    .blog-card__date {
        display: flex;
        align-items: center;
        gap: 6px;
        margin: 0;
        color: #8c94a1;
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 400;
        line-height: 18px;
        letter-spacing: 1px;
    }

    .blog-card__tree {
        color: #4a5260;
        font-size: 12px;
    }

    .blog-card__category {
        flex-shrink: 0;
        color: #4a5260;
        font-family: var(--font-body);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        white-space: nowrap;
    }

    @media (max-width: 640px) {
        .blog-card__link {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
            padding: 20px 24px;
        }

        .blog-card__title {
            font-size: 18px;
            line-height: 26px;
        }

        .blog-card__category {
            display: none;
        }
    }
</style>
