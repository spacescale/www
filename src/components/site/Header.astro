---
type NavItem = {
    label: string;
    href: string;
    external?: boolean;
};

const navItems: NavItem[] = [
    {
        label: "Principles",
        href: "/principles",
    },
    {
        label: "Blog",
        href: "/blog",
    },
];

const navSocials = [
    {
        label: "SpaceScale on GitHub",
        href: "https://github.com/spacescale",
        icon: "/assets/social/github.svg",
    },
    {
        label: "SpaceScale on LinkedIn",
        href: "https://www.linkedin.com/company/spacescale",
        icon: "/assets/social/linkedin.svg",
    },
    {
        label: "SpaceScale on YouTube",
        href: "#",
        icon: "/assets/social/youtube.svg",
    },
] as const;
---

<header
    class="site-header"
    aria-label="Primary navigation"
    data-site-header
    transition:persist
>
    <div class="site-header-inner">
        <a class="brand-lockup" href="/" aria-label="SpaceScale home">
            <span class="brand-mark" aria-hidden="true">
                <!-- These empty spans become the SpaceScale square-dot logo in CSS. -->
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
            </span>

            <span class="brand-name">SpaceScale</span>
        </a>

        <button
            class="site-menu-toggle"
            type="button"
            aria-controls="site-nav"
            aria-expanded="false"
            aria-label="Open main menu"
            data-site-menu-toggle
        >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
        </button>

        <nav id="site-nav" class="site-nav" aria-label="Main menu" data-site-nav>
            <div class="site-nav-list">
                {
                    navItems.map((item) => (
                        <a
                            class="site-nav-row site-nav-link"
                            href={item.href}
                            {...(item.external ? { target: "_blank", rel: "noreferrer noopener" } : {})}
                        >
                            <span class="site-nav-label">{item.label}</span>
                            <span class="site-nav-caret" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                                    <path d="M9 6l6 6-6 6" />
                                </svg>
                            </span>
                        </a>
                    ))
                }
            </div>

            <div class="site-nav-footer">
                <a class="nav-cta" href="/blog">Read how we are building it</a>

                <div class="site-nav-socials" aria-label="Social links">
                    {
                        navSocials.map((link) => (
                            <a href={link.href} aria-label={link.label}>
                                <span
                                    class="site-social-icon"
                                    style={`--site-social-icon: url(${link.icon})`}
                                    aria-hidden="true"
                                />
                            </a>
                        ))
                    }
                </div>
            </div>
        </nav>
    </div>
</header>

<script>
    let cleanupSiteHeader: (() => void) | undefined;

    const initializeSiteHeader = () => {
        cleanupSiteHeader?.();
        cleanupSiteHeader = undefined;

        document.querySelectorAll("[data-site-header]").forEach((header) => {
            const toggle = header.querySelector("[data-site-menu-toggle]");
            const nav = header.querySelector("[data-site-nav]");

            if (!(toggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) {
                return;
            }

            const controller = new AbortController();
            const { signal } = controller;
            const mobileQuery = window.matchMedia("(max-width: 640px)");

            const closeMenu = () => {
                header.removeAttribute("data-menu-open");
                toggle.setAttribute("aria-expanded", "false");
                toggle.setAttribute("aria-label", "Open main menu");
                document.body.style.overflow = "";
            };

            const openMenu = () => {
                header.setAttribute("data-menu-open", "true");
                toggle.setAttribute("aria-expanded", "true");
                toggle.setAttribute("aria-label", "Close main menu");
                if (mobileQuery.matches) {
                    document.body.style.overflow = "hidden";
                }
            };

            toggle.addEventListener("click", () => {
                const isOpen = header.getAttribute("data-menu-open") === "true";
                if (isOpen) {
                    closeMenu();
                } else {
                    openMenu();
                }
            }, { signal });

            nav.querySelectorAll("a").forEach((link) => {
                link.addEventListener("click", closeMenu, { signal });
            });

            mobileQuery.addEventListener("change", (event) => {
                if (!event.matches) {
                    closeMenu();
                }
            }, { signal });

            document.addEventListener("keydown", (event) => {
                if (event.key === "Escape" && header.getAttribute("data-menu-open") === "true") {
                    closeMenu();
                }
            }, { signal });

            cleanupSiteHeader = () => {
                closeMenu();
                controller.abort();
            };
        });
    };

    initializeSiteHeader();
    document.addEventListener("astro:page-load", initializeSiteHeader);
</script>
