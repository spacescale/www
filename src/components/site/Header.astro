---
// Header component with navigation
---

<header class="fixed top-0 left-0 right-0 z-50 bg-background">
  <nav class="container mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <div class="flex items-center space-x-2">
        <img src="/images/logos/logo.svg" alt="SpaceScale Logo" />
      </div>

      <!-- Desktop Navigation and CTA -->
      <div class="hidden md:flex items-center space-x-8">
        <a
          href="/engineering"
          class="text-text-secondary text-[14px] font-500 hover:text-text-primary transition-colors"
        >
          Engineering
        </a>
        <a
          href="https://linkedin.com/company/spacescale"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-secondary text-[14px] font-500 hover:text-text-primary transition-colors"
        >
          LinkedIn
        </a>
        <a
          href="/engineering"
          class="bg-text-light text-background cursor-pointer px-4 py-2 font-medium text-[14px] hover:opacity-90 transition-opacity"
        >
          Read how we are building it
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-text-secondary"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden mt-4 pt-4 border-t border-border-default">
      <div class="flex flex-col space-y-4">
        <a
          href="/engineering"
          class="text-text-secondary text-[14px] font-500 hover:text-text-primary transition-colors"
        >
          Engineering
        </a>
        <a
          href="https://linkedin.com/company/spacescale"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-secondary text-[14px] font-500 hover:text-text-primary transition-colors"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
