---

<div class="final-cta-footer-frame">
    <div class="final-cta-footer-frame__background" aria-hidden="true">
        {
            lowerFrameTiles.map((tile) => (
                <span style={`--tile-x: ${tile.x}px; --tile-y: ${tile.y}px;`} />
            ))
        }
    </div>
    <slot />
    <Footer />
</div>

<style>
    .final-cta-footer-frame {
        position: relative;
        z-index: 0;
        overflow: hidden;
        background: var(--color-bg-primary);
        isolation: isolate;
    }

    .final-cta-footer-frame__background {
        position: absolute;
        z-index: 0;
        top: 232.4365px;
        left: 40px;
        width: 1321.0002px;
        height: 706.3489px;
        pointer-events: none;
    }

    .final-cta-footer-frame__background span {
        position: absolute;
        top: var(--tile-y);
        left: var(--tile-x);
        width: 88.0667px;
        height: 88.0667px;
        background: linear-gradient(180deg, #ffffff 0%, #999999 100%);
        opacity: 0.02;
    }

    .final-cta-footer-frame :global(.final-cta),
    .final-cta-footer-frame :global(.site-footer) {
        position: relative;
        z-index: 1;
        background: transparent;
    }

    .final-cta-footer-frame :global(.site-footer) {
        padding-bottom: 59px;
    }
</style>
