---
import Badge from "../ui/Badge.astro";

/*
  Footer.astro is the shared footer for marketing pages.

  We keep footer link data in arrays so the markup stays clean.
  Later, if links change, we edit the arrays instead of rewriting HTML.
*/

const footerGroups = [
    {
        title: "Resources",
        links: [
            { label: "Documentation", href: "#" },
            { label: "Changelog", href: "#" },
            { label: "Partnerships", href: "#" },
        ],
    },
    {
        title: "Blog",
        links: [
            { label: "Engineering", href: "/engineering" },
            { label: "Tutorials", href: "#" },
        ],
    },
    {
        title: "Company",
        links: [
            { label: "Principles", href: "/principles" },
            { label: "Careers", href: "#" },
            { label: "Privacy Policy", href: "#" },
        ],
    },
];

const socialLinks = [
    {
        label: "SpaceScale on LinkedIn",
        href: "https://www.linkedin.com/company/spacescale",
        icon: "/assets/social/linkedin.svg",
    },
    {
        label: "SpaceScale on GitHub",
        href: "https://github.com/spacescale",
        icon: "/assets/social/github.svg",
    },
    {
        label: "SpaceScale on YouTube",
        href: "#",
        icon: "/assets/social/youtube.svg",
    },
] as const;
---

<footer class="site-footer" transition:persist>
    <div class="footer-divider" aria-hidden="true"></div>

    <div class="footer-inner">
        <section class="footer-brand" aria-label="SpaceScale">
            <h2>Infrastructure for<br />humans and agents</h2>
            <Badge
                icon="status"
                size="compact"
                ariaLabel="System status: All systems operational"
            >
                All systems operational
            </Badge>

            <div class="social-links" aria-label="Social links">
                {
                    socialLinks.map((link) => (
                        <a href={link.href} aria-label={link.label}>
                            <span
                                class="site-social-icon"
                                style={`--site-social-icon: url(${link.icon})`}
                                aria-hidden="true"
                            />
                        </a>
                    ))
                }
            </div>
        </section>

        <nav class="footer-links" aria-label="Footer navigation">
            {
                footerGroups.map((group) => (
                    <section>
                        <h3>{group.title}</h3>

                        <ul>
                            {group.links.map((link) => (
                                <li>
                                    <a href={link.href}>{link.label}</a>
                                </li>
                            ))}
                        </ul>
                    </section>
                ))
            }
        </nav>
    </div>
</footer>
