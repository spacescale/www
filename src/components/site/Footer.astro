---
import SocialIcon from "../icons/SocialIcon.astro";

/*
  Footer.astro is the shared footer for marketing pages.

  We keep footer link data in arrays so the markup stays clean.
  Later, if links change, we edit the arrays instead of rewriting HTML.
*/

const footerGroups = [
    {
        title: "Resources",
        links: ["Documentation", "Tutorials", "API", "Changelog"],
    },
    {
        title: "Engineering",
        links: ["Blog", "GitHub", "Status", "Docs"],
    },
    {
        title: "Company",
        links: ["About", "Philosophy", "Contact"],
    },
];

const legalLinks = ["Privacy", "Terms", "Security"];

const socialLinks = [
    {
        name: "linkedin",
        label: "SpaceScale on LinkedIn",
        href: "https://www.linkedin.com/company/spacescale",
    },
    {
        name: "github",
        label: "SpaceScale on GitHub",
        href: "https://github.com/spacescale",
    },
    {
        name: "youtube",
        label: "SpaceScale on YouTube",
        href: "#",
    },
] as const;
---

<footer class="site-footer">
    <div class="footer-inner">
        <section class="footer-brand" aria-label="SpaceScale">
            <h2>The Hyper-PaaS for<br />Serious Workloads</h2>
            <div class="status-badge" aria-label="System status">
                <span aria-hidden="true"></span>
                All systems operational
            </div>

            <div class="social-links" aria-label="Social links">
                {
                    socialLinks.map((link) => (
                        <a href={link.href} aria-label={link.label}>
                            <SocialIcon name={link.name} />
                        </a>
                    ))
                }
            </div>
        </section>

        <nav class="footer-links" aria-label="Footer navigation">
            {
                footerGroups.map((group) => (
                    <section>
                        <h3>{group.title}</h3>

                        <ul>
                            {group.links.map((link) => (
                                <li>
                                    <a href="#">{link}</a>
                                </li>
                            ))}
                        </ul>
                    </section>
                ))
            }
        </nav>
    </div>

    <div class="footer-divider" aria-hidden="true"></div>

    <div class="footer-bottom">
        <p>© 2026 SpaceScale Systems Inc.</p>
        <nav aria-label="Legal links">
            {
                legalLinks.map((link) => (
                    <a href="#">{link}</a>
                ))
            }
        </nav>
    </div>
</footer>
