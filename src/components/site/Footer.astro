---
// Footer component with navigation and links
---

<footer class=" border-t border-border-default bg-background">
  <div class="container mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-6 gap-8 pt-20 pb-10">
      <!-- Logo and Description -->
      <div class="col-span-1 md:col-span-2">
        <h1 class="font-hero text-text-white text-[34px] font-400 mb-4 max-w-md">
          The Hyper-PaaS for Serious Workloads.
        </h1>
        <div class="flex space-x-4">
          <a
            href="#"
            class="text-text-white hover:text-text-primary transition-colors"
          >
            <img
              src="/images/site/linkedln.svg"
              alt="LinkedIn"
              class="h-5 w-5"
            />
          </a>
          <a
            href="#"
            class="text-text-white hover:text-text-primary transition-colors"
          >
            <img src="/images/site/github.svg" alt="GitHub" class="h-5 w-5" />
          </a>
          <a
            href="#"
            class="text-text-white hover:text-text-primary transition-colors"
          >
            <img src="/images/blog/youtube.svg" alt="YouTube" class="h-5 w-5" />
          </a>
        </div>
      </div>

      <!-- Spacer to push Product and Company sections to the right -->
      <div class="hidden md:block md:col-span-1"></div>

      <!-- Product and Company sections moved to extreme end -->
      <div class="flex flex-row gap-8 col-span-1 md:col-span-4 md:col-start-6">
        <!-- Product -->
        <div class="flex flex-col">
          <h3 class="text-text-secondary font-600 mb-4 text-[13px]">RESOURCES</h3>
          <ul class="space-y-2">
            <li>
              <a
                href="/features"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                Documentation
              </a>
            </li>
            <li>
              <a
                href="/pricing"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                Tutorials
              </a>
            </li>
            <li>
              <a
                href="/docs"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                API
              </a>
            </li>
            <li>
              <a
                href="/api"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                Changelog
              </a>
            </li>
          </ul>
        </div>

        <!-- Engineering -->
        <div class="flex flex-col">
          <h3 class="text-text-secondary font-600 text-[13px] mb-4">Engineering</h3>
          <ul class="space-y-2">
            <li>
              <a
                href="/engineering"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                Blog
              </a>
            </li>
            <li>
              <a
                href="/blog"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                GitHub
              </a>
            </li>
            <li>
              <a
                href="/status"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                Status
              </a>
            </li>
            <li>
              <a
                href="/docs"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                Docs
              </a>
            </li>
          </ul>
        </div>

        <!-- Company -->
        <div class="flex flex-col">
          <h3 class="text-text-secondary font-600 mb-4 text-[13px]">Company</h3>
          <ul class="space-y-2">
            <li>
              <a
                href="/about"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                About
              </a>
            </li>
            <li>
              <a
                href="/blog"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                Philosophy
              </a>
            </li>
            <li>
              <a
                href="/contact"
                class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
              >
                Contact
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Section -->
    <div
      class="border-t border-border-default mt-8 py-12 flex flex-col md:flex-row justify-between items-center"
    >
      <p class="text-text-secondary text-[13px] mb-4 md:mb-0">
        © {new Date().getFullYear()} SpaceScale. Inc.
      </p>
      <div class="flex space-x-6">
        <a
          href="/privacy"
          class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
        >
          Privacy
        </a>
        <a
          href="/terms"
          class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
        >
          Terms
        </a>
        <a
          href="/security"
          class="text-text-secondary hover:text-text-primary transition-colors text-[13px]"
        >
          Security
        </a>
      </div>
    </div>
  </div>
</footer>
