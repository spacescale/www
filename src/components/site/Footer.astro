---
/*
  Footer.astro is the shared footer for marketing pages.

  We keep footer link data in arrays so the markup stays clean.
  Later, if links change, we edit the arrays instead of rewriting HTML.
*/

const footerGroups = [
    {
        title: "Resources",
        links: ["Documentation", "Tutorials", "API", "Changelog"],
    },
    {
        title: "Engineering",
        links: ["Blog", "GitHub", "Status", "Docs"],
    },
    {
        title: "Company",
        links: ["About", "Philosophy", "Contact"],
    },
];

const legalLinks = ["Privacy", "Terms", "Security"];
---

<footer class="site-footer">
    <div class="footer-inner">
        <section class="footer-brand" aria-label="SpaceScale">
            <h2>The Hyper-PaaS for<br />Serious Workloads.</h2>
            <div class="status-badge" aria-label="System status">
                <span aria-hidden="true"></span>
                All systems operational
            </div>

            <div class="social-links" aria-label="Social links">
                <a href="https://www.linkedin.com/company/spacescale" aria-label="SpaceScale on LinkedIn">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path
                            fill="currentColor"
                            d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.28 8.25h4.44V23H.28V8.25ZM8.08 8.25h4.25v2.02h.06c.59-1.12 2.04-2.3 4.2-2.3 4.49 0 5.32 2.96 5.32 6.8V23h-4.43v-7.29c0-1.74-.03-3.98-2.43-3.98-2.43 0-2.8 1.9-2.8 3.86V23H7.82V8.25h.26Z"
                        />
                    </svg>
                </a>

                <a href="https://github.com/spacescale" aria-label="SpaceScale on GitHub">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path
                            fill="currentColor"
                            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18A10.9 10.9 0 0 1 12 6.04c.98 0 1.96.13 2.88.39 2.19-1.49 3.15-1.18 3.15-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.77 1.06.77 2.13v3.18c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
                        />
                    </svg>
                </a>

                <a href="#" aria-label="SpaceScale on YouTube">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path
                            fill="currentColor"
                            d="M23.5 6.2a3 3 0 0 0-2.11-2.12C19.53 3.58 12 3.58 12 3.58s-7.53 0-9.39.5A3 3 0 0 0 .5 6.2 31.24 31.24 0 0 0 0 12a31.24 31.24 0 0 0 .5 5.8 3 3 0 0 0 2.11 2.12c1.86.5 9.39.5 9.39.5s7.53 0 9.39-.5a3 3 0 0 0 2.11-2.12A31.24 31.24 0 0 0 24 12a31.24 31.24 0 0 0-.5-5.8ZM9.55 15.57V8.43L15.82 12l-6.27 3.57Z"
                        />
                    </svg>
                </a>
            </div>
        </section>

        <nav class="footer-links" aria-label="Footer navigation">
            {
                footerGroups.map((group) => (
                    <section>
                        <h3>{group.title}</h3>

                        <ul>
                            {group.links.map((link) => (
                                <li>
                                    <a href="#">{link}</a>
                                </li>
                            ))}
                        </ul>
                    </section>
                ))
            }
        </nav>
    </div>

    <div class="footer-divider" aria-hidden="true"></div>

    <div class="footer-bottom">
        <p>© 2026 SpaceScale, Inc.</p>
        <nav aria-label="Legal links">
            {
                legalLinks.map((link) => (
                    <a href="#">{link}</a>
                ))
            }
        </nav>
    </div>
</footer>
