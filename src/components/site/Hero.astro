---
// Hero section 
---

<section class="relative min-h-screen bg-background overflow-hidden">
  <div class="absolute inset-0 dot-grid opacity-20 pointer-events-none"></div>

  <div class="relative z-10 grid grid-cols-1 lg:grid-cols-5 min-h-screen">
   
    <div
      class="flex flex-col col-span-3 justify-center px-6 xl:px-28 pt-32 pb-16 lg:pt-40 lg:pb-0"
    >
      <div class="flex flex-col gap-7 w-full">
        <div class="flex flex-col gap-7 max-w-[600px]">
          <div
            class="inline-flex w-fit items-center gap-2 border border-border-default rounded-sm px-3 py-1.5"
          >
            <span
              class="font-body text-text-secondary text-[13px] leading-none"
            >
              Currently in active development — follow our story
            </span>
          </div>

      
          <div class="flex flex-col gap-4">
            <h1
              class="font-hero font-400 text-text-primary leading-[72px] tracking-[-0.02em] text-[64px]"
            >
              The Hyper-PaaS for<br />Serious Workloads.
            </h1>
            <p
              class="font-body text-text-secondary text-[16px] leading-[26px] text-wrap"
            >
              A serverless deployment platform built for workloads that break
              standard PaaS. Deploy containers onto high-performance, isolated
              compute with zero ops overhead.
            </p>
          </div>

          <!-- CTA -->
          <div>
            <a
              href="/blog"
              class="inline-flex items-center gap-2 border border-white font-body font-600 text-text-primary text-[16px] px-5 py-2.5 hover:bg-card transition-colors"
            >
              Read how we're building it
            </a>
          </div>
        </div>

        <!-- Tabbed terminal — full column width -->
        <div class="overflow-hidden w-full" id="hero-terminal">
          <div
            class="flex border border-border-default overflow-x-auto w-1/4 bg-background !overflow-hidden"
          >
            <button
              class="tab-btn cursor-pointer px-4 py-2.5 font-terminal text-[12px] tracking-wider text-accent-mint border-b-2 border-accent-mint -mb-px transition-colors whitespace-nowrap"
              data-tab="cli">CLI</button
            >
            <button
              class="tab-btn cursor-pointer px-4 py-2.5 font-terminal text-[12px] tracking-wider text-text-secondary border-b-2 border-transparent -mb-px transition-colors hover:text-accent-mint whitespace-nowrap"
              data-tab="api">API</button
            >
            <button
              class="tab-btn cursor-pointer px-4 py-2.5 font-terminal text-[12px] tracking-wider text-text-secondary border-b-2 border-transparent -mb-px transition-colors hover:text-accent-mint whitespace-nowrap"
              data-tab="console">CONSOLE</button
            >
          </div>

         
          <div class="w-full">
            <div
              class="tab-panel border border-border-default bg-terminal p-3 sm:p-4 md:p-5 font-terminal w-full text-[10px] sm:text-[11px] md:text-[12px] lg:text-[13px] space-y-1 sm:space-y-2"
              data-panel="cli"
            >
              <div class="flex items-center gap-2">
                <span class="text-accent-mint-light select-none">$</span>
                <span class="text-text-accent-mint-light"
                  >spacescale deploy ./app --region eu-west</span
                >
              </div>
              <div class="flex items-center gap-2 font-terminal">
                <span class="text-accent-mint-light">→</span>
                <span class="text-accent-mint-light"
                  >pushing image<span class="opacity-50">...</span> done</span
                >
              </div>
              <div class="flex items-center gap-2 font-terminal">
                <span class="text-accent-mint-light">→</span>
                <span class="text-accent-mint-light"
                  >booting microVM in fra1<span class="opacity-60">...</span> 412ms</span
                >
              </div>
              <div class="flex items-center gap-2 font-terminal">
                <span class="text-accent-mint-light">→</span>
                <span class="text-accent-mint-light"
                  >live at <span class="text-text-accent-mint-light"
                    >https://app.spacescale.run</span
                  ></span
                >
              </div>
              <div class="flex items-center gap-2 pt-1 font-terminal">
                <span class="text-accent-mint-light select-none">$</span>
                <span class="text-text-primary cursor-blink">▋</span>
              </div>
            </div>


            <div
              class="tab-panel border border-border-default bg-terminal p-3 sm:p-4 md:p-5 font-terminal w-full text-[10px] sm:text-[11px] md:text-[12px] lg:text-[13px] space-y-1 sm:space-y-2"
              data-panel="api"
            >
              <div class="text-text-secondary">
                POST <span class="text-text-accent-mint-light">/v1/deployments</span>
              </div>
              <div class="text-text-secondary">
                Authorization: Bearer <span class="text-accent-mint"
                  >sk_live_••••••••</span
                >
              </div>
              <div class="mt-2 text-text-secondary">
                {"{"}
                <div class="pl-4">
                  "image": <span class="text-accent-mint"
                    >"registry.spacescale.run/app:latest"</span
                  >,
                </div>
                <div class="pl-4">
                  "region": <span class="text-accent-mint">"eu-west"</span>,
                </div>
                <div class="pl-4">
                  "replicas": <span class="text-accent-mint">3</span>
                </div>
                {"}"}
              </div>
            </div>

           
            <div
              class="tab-panel border border-border-default bg-terminal p-3 sm:p-4 md:p-5 font-terminal w-full text-[10px] sm:text-[11px] md:text-[12px] lg:text-[13px] space-y-1 sm:space-y-2"
              data-panel="console"
            >
              <div class="flex items-center gap-3">
                <span class="text-text-secondary text-[11px] w-16 shrink-0"
                  >12:34:57</span
                >
                <span class="text-blue-400">[stdout]</span>
                <span class="text-text-accent-mint-light"
                  >Server listening on :3000</span
                >
              </div>
              <div class="flex items-center gap-3">
                <span class="text-text-secondary text-[11px] w-16 shrink-0"
                  >12:34:58</span
                >
                <span class="text-blue-400">[event]</span>
                <span class="text-text-accent-mint-light">Health check passed</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-text-secondary text-[11px] w-16 shrink-0"
                  >12:35:01</span
                >
                <span class="text-blue-400">[stdout]</span>
                <span class="text-text-accent-mint-light"
                  >GET /api/status 200 — 3ms</span
                >
              </div>
              <div class="flex items-center gap-3">
                <span class="text-text-accent-mint-light text-[11px] w-16 shrink-0"
                  >12:35:04</span
                >
                <span class="text-accent-mint">[metric]</span>
                <span class="text-text-accent-mint-light">cpu=14% mem=312MB</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    
    <div
      class="hidden lg:flex col-span-2 items-center justify-start relative overflow-visible"
    >
      <div
        class="w-full h-auto -mr-[10%] -translate-x-[40%] pointer-events-none select-none"
      >
        <svg
          viewBox="0 0 680 500"
          xmlns="http://www.w3.org/2000/svg"
          class="w-[200%] h-[150%]"
        >
          <style>
            @keyframes pulse {
              0%,
              100% {
                opacity: 0.3;
              }
              50% {
                opacity: 0.8;
              }
            }
            @keyframes dash {
              to {
                stroke-dashoffset: -20;
              }
            }
            @keyframes spinMeridianA {
              0% {
                rx: 60;
              }
              25% {
                rx: 0;
              }
              50% {
                rx: 60;
              }
              75% {
                rx: 180;
              }
              100% {
                rx: 60;
              }
            }
            @keyframes spinMeridianB {
              0% {
                rx: 120;
              }
              25% {
                rx: 60;
              }
              50% {
                rx: 0;
              }
              75% {
                rx: 60;
              }
              100% {
                rx: 120;
              }
            }
            @keyframes spinMeridianC {
              0% {
                rx: 180;
              }
              25% {
                rx: 120;
              }
              50% {
                rx: 60;
              }
              75% {
                rx: 0;
              }
              100% {
                rx: 180;
              }
            }
            .globe-line {
              fill: none;
              stroke: #8b8d94;
              stroke-width: 0.5;
              stroke-dasharray: 4 4;
              opacity: 0.3;
            }
            .globe-outer {
              fill: none;
              stroke: #8b8d94;
              stroke-width: 0.5;
              stroke-dasharray: 6 6;
              opacity: 0.3;
            }
            .globe-equator {
              fill: none;
              stroke: #8b8d94;
              stroke-width: 0.5;
              stroke-dasharray: 4 4;
              opacity: 0.3;
            }
            .meridian {
              fill: none;
              stroke: #8b8d94;
              stroke-width: 0.5;
              stroke-dasharray: 4 4;
              opacity: 0.2;
              transform-origin: center;
            }
            .m1 {
              animation: spinMeridianA 20s linear infinite;
            }
            .m2 {
              animation: spinMeridianB 20s linear infinite;
            }
            .node-glow {
              animation: pulse 3s ease-in-out infinite;
            }
            .data-line {
              fill: none;
              stroke: #66d9a5;
              stroke-width: 0.8;
              stroke-dasharray: 3 6;
              animation: dash 2s linear infinite;
              opacity: 0.4;
            }
            .region-node {
              fill: #66d9a5;
              opacity: 0.9;
            }
            .region-ring {
              fill: none;
              stroke: #66d9a5;
              stroke-width: 0.5;
              opacity: 0.25;
            }
            .lbl {
              font-family: "Articulat CF", Inter, system-ui, sans-serif;
              font-size: 10px;
              fill: #3d3d3a;
              opacity: 0.7;
            }
            @media (max-width: 640px) {
              .lbl {
                font-size: 8px;
              }
            }
          </style>

          <g transform="translate(340,250)">
            <ellipse class="globe-outer" cx="0" cy="0" rx="180" ry="180"
            ></ellipse>
            <ellipse class="globe-equator" cx="0" cy="0" rx="180" ry="60"
            ></ellipse>
            <ellipse
              class="globe-line"
              cx="0"
              cy="0"
              rx="180"
              ry="120"
              transform="rotate(25)"></ellipse>
            <ellipse
              class="globe-line"
              cx="0"
              cy="0"
              rx="180"
              ry="120"
              transform="rotate(-25)"></ellipse>
            <ellipse class="meridian m1" cx="0" cy="0" rx="60" ry="180"
            ></ellipse>
            <ellipse class="meridian m2" cx="0" cy="0" rx="120" ry="180"
            ></ellipse>
            <ellipse
              class="meridian"
              cx="0"
              cy="0"
              rx="180"
              ry="180"
              style="opacity:.08"></ellipse>
            <ellipse
              class="meridian"
              cx="0"
              cy="0"
              rx="30"
              ry="180"
              style="opacity:.1;animation:spinMeridianA 20s linear infinite;animation-delay:-5s"
            ></ellipse>
            <ellipse
              class="meridian"
              cx="0"
              cy="0"
              rx="90"
              ry="180"
              style="opacity:.12;animation:spinMeridianB 20s linear infinite;animation-delay:-5s"
            ></ellipse>
            <ellipse
              class="meridian"
              cx="0"
              cy="0"
              rx="150"
              ry="180"
              style="opacity:.1;animation:spinMeridianC 20s linear infinite;animation-delay:-5s"
            ></ellipse>
            <line
              class="globe-line"
              x1="0"
              y1="-180"
              x2="0"
              y2="180"
              opacity=".15"></line>
            <line
              class="globe-line"
              x1="-180"
              y1="0"
              x2="180"
              y2="0"
              opacity=".15"></line>
            <line class="data-line" x1="-140" y1="-80" x2="-60" y2="60"></line>
            <line class="data-line" x1="-60" y1="60" x2="100" y2="30"></line>
            <line class="data-line" x1="100" y1="30" x2="150" y2="-60"></line>
            <line class="data-line" x1="-140" y1="-80" x2="100" y2="30"></line>
            <line class="data-line" x1="-60" y1="60" x2="60" y2="-120"></line>
            <line class="data-line" x1="60" y1="-120" x2="150" y2="-60"></line>
            <line class="data-line" x1="-140" y1="-80" x2="60" y2="-120"></line>
            <g class="node-glow" style="animation-delay:0s">
              <circle class="region-ring" cx="-140" cy="-80" r="12"></circle>
              <circle class="region-node" cx="-140" cy="-80" r="4"></circle>
            </g>
            <g class="node-glow" style="animation-delay:.6s">
              <circle class="region-ring" cx="-60" cy="60" r="12"></circle>
              <circle class="region-node" cx="-60" cy="60" r="4"></circle>
            </g>
            <g class="node-glow" style="animation-delay:1.2s">
              <circle class="region-ring" cx="100" cy="30" r="12"></circle>
              <circle class="region-node" cx="100" cy="30" r="4"></circle>
            </g>
            <g class="node-glow" style="animation-delay:1.8s">
              <circle class="region-ring" cx="150" cy="-60" r="12"></circle>
              <circle class="region-node" cx="150" cy="-60" r="4"></circle>
            </g>
            <g class="node-glow" style="animation-delay:2.4s">
              <circle class="region-ring" cx="60" cy="-120" r="12"></circle>
              <circle class="region-node" cx="60" cy="-120" r="4"></circle>
            </g>
            <text class="lbl" x="-155" y="-95">us-east</text>
            <text class="lbl" x="-75" y="80">eu-west</text>
            <text class="lbl" x="110" y="48">ap-south</text>
            <text class="lbl" x="158" y="-68">ap-east</text>
            <text class="lbl" x="68" y="-128">us-west</text>
          </g>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .dot-grid {
    background-image: radial-gradient(circle, #1e2028 1px, transparent 1px);
    background-size: 28px 28px;
  }
  .cursor-blink {
    animation: blink 1.1s step-start infinite;
  }
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  const terminal = document.getElementById("hero-terminal");
  if (terminal) {
    terminal.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.tab;
        terminal
          .querySelectorAll<HTMLButtonElement>(".tab-btn")
          .forEach((b) => {
            b.classList.remove("text-accent-mint", "border-accent-mint");
            b.classList.add("text-text-secondary", "border-transparent");
          });
        btn.classList.remove("text-text-secondary", "border-transparent");
        btn.classList.add("text-accent-mint", "border-accent-mint");
        terminal
          .querySelectorAll<HTMLElement>(".tab-panel")
          .forEach((panel) => {
            panel.classList.toggle("hidden", panel.dataset.panel !== target);
          });
      });
    });
  }
</script>
