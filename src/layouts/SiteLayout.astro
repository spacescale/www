---
import FinalCtaFooterFrame from "../components/site/FinalCtaFooterFrame.astro";
import Footer from "../components/site/Footer.astro";
import Header from "../components/site/Header.astro";
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "SpaceScale: Infrastructure for humans and agents",
    description = "SpaceScale is building infrastructure for humans and agents, with Ignite for container workloads and Machines for persistent workspaces.",
} = Astro.props;

const hasFinalCta = Astro.slots.has("final-cta");
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link
            rel="icon"
            href="/favicon-light.svg"
            type="image/svg+xml"
            media="(prefers-color-scheme: light)"
            sizes="any"
        />
        <link
            rel="icon"
            href="/favicon-dark.svg"
            type="image/svg+xml"
            media="(prefers-color-scheme: dark)"
            sizes="any"
        />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
        <link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml" />
        <title>{title}</title>
    </head>

    <body>
        <Header />
        <slot />
        {
            hasFinalCta ? (
                <FinalCtaFooterFrame>
                    <slot name="final-cta" />
                </FinalCtaFooterFrame>
            ) : (
                <Footer />
            )
        }
    </body>
</html>
