---
import { ClientRouter } from "astro:transitions";
import Footer from "../components/site/Footer.astro";
import Header from "../components/site/Header.astro";
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    enableViewTransitions?: boolean;
}

const {
    title = "SpaceScale: Infrastructure for humans and agents",
    description = "SpaceScale is building infrastructure for humans and agents, with Ignite for container workloads and Machines for persistent workspaces.",
    image,
    enableViewTransitions = false,
} = Astro.props;

const hasFinalCta = Astro.slots.has("final-cta");
const siteOrigin = Astro.site?.toString() ?? "https://spacescale.io";
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const imageUrl = image ? new URL(image, siteOrigin).toString() : undefined;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={pageUrl} />
        {imageUrl && <meta property="og:image" content={imageUrl} />}
        <link rel="canonical" href={pageUrl} />
        <meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        {imageUrl && <meta name="twitter:image" content={imageUrl} />}
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
        <link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml" />
        <title>{title}</title>
        {enableViewTransitions && <ClientRouter />}
    </head>

    <body>
        <Header />
        <div class="site-main">
            <slot />
        </div>
        {hasFinalCta && <slot name="final-cta" />}
        <Footer />
    </body>
</html>
