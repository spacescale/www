---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
    title="404 | SpaceScale"
    description="This SpaceScale route could not be found."
>
    <main class="not-found">
        <section class="not-found__hero-section">
            <article class="not-found__shell">
                <header class="not-found__hero">
                    <p class="not-found__eyebrow">ROUTE STATUS</p>
                    <h1>
                        <span>404</span>
                        Route not found
                    </h1>
                </header>
            </article>
        </section>

        <section class="not-found__content-section">
            <div class="not-found__bar-layer" aria-hidden="true">
                <div class="not-found__bar"></div>
            </div>

            <article class="not-found__shell">
                <section class="not-found__card">
                    <div class="not-found__copy">
                        <p class="not-found__kicker">No endpoint mapped</p>
                        <p class="not-found__status">
                            This page does not exist, or it may have moved.
                        </p>
                        <p>
                            Head back to the homepage and continue from a known SpaceScale path.
                        </p>
                        <div class="not-found__actions">
                            <a class="not-found__primary" href="/">Return home</a>
                        </div>
                    </div>

                    <aside class="not-found__trace" aria-label="Route trace">
                        <div class="not-found__trace-header">
                            <p>REQUEST TRACE</p>
                            <span>unmapped</span>
                        </div>
                        <div class="not-found__trace-lines">
                            <p><span>GET</span> {Astro.url.pathname}</p>
                            <p><span>status</span> 404 not_found</p>
                            <p><span>router</span> no endpoint mapped</p>
                            <p><span>action</span> return to healthy route</p>
                        </div>
                    </aside>
                </section>
            </article>
        </section>
    </main>
</SiteLayout>

<style>
    .not-found {
        --not-found-rail-width: 80px;

        position: relative;
        display: flex;
        width: 100%;
        flex-direction: column;
        align-items: center;
        overflow: clip;
        background: var(--color-bg-primary);
        color: #f5f7fa;
    }

    .not-found__hero-section,
    .not-found__content-section {
        display: flex;
        width: 100%;
        justify-content: center;
        background: var(--color-bg-primary);
    }

    .not-found__hero-section {
        padding: 32px var(--site-padding-x) 0;
    }

    .not-found__content-section {
        position: relative;
        padding: 64px var(--site-padding-x) 120px;
        overflow: clip;
    }

    .not-found__shell {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 1280px;
    }

    .not-found__hero {
        position: relative;
        width: 100%;
        padding: 70px 0 20px;
    }

    .not-found__hero::after {
        position: absolute;
        bottom: 0;
        left: 50%;
        width: 100vw;
        height: 1px;
        background-image: repeating-linear-gradient(
            to right,
            #262b33 0,
            #262b33 6px,
            transparent 6px,
            transparent 12px
        );
        transform: translateX(-50%);
        content: "";
    }

    .not-found__eyebrow,
    .not-found__hero h1 {
        margin: 0;
    }

    .not-found__eyebrow,
    .not-found__kicker,
    .not-found__trace-header,
    .not-found__trace-lines {
        font-family: var(--font-mono);
        letter-spacing: 1.04px;
        text-transform: uppercase;
    }

    .not-found__eyebrow {
        margin-bottom: 18px;
        color: #8c94a1;
        font-size: 13px;
        font-weight: 500;
        line-height: normal;
    }

    .not-found__hero h1 {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: baseline;
        color: #ffffff;
        font-family: var(--font-display);
        font-size: 44px;
        font-weight: 400;
        line-height: 52px;
        letter-spacing: -0.66px;
    }

    .not-found__hero h1 span {
        color: #040406;
        background: #66d9b2;
        padding: 0 12px 4px;
    }

    .not-found__card {
        display: grid;
        min-height: 420px;
        grid-template-columns: minmax(0, 1fr) 420px;
        gap: 72px;
        align-items: center;
        border: 1px solid #262b33;
        padding: 72px 88px;
        background:
            linear-gradient(180deg, rgb(255 255 255 / 1.8%) 0, transparent 180px),
            var(--color-bg-primary);
    }

    .not-found__copy {
        max-width: 640px;
    }

    .not-found__kicker {
        margin: 0 0 18px;
        color: #d95a5a;
        font-size: 13px;
        font-weight: 500;
        line-height: normal;
    }

    .not-found__status {
        margin: 0;
        color: #ffffff;
        font-family: var(--font-display);
        font-size: 28px;
        font-weight: 400;
        line-height: 36px;
        letter-spacing: -0.28px;
    }

    .not-found__copy > p:not(.not-found__kicker, .not-found__status) {
        max-width: 560px;
        margin: 14px 0 0;
        color: #8c94a1;
        font-family: var(--font-body);
        font-size: 17px;
        font-weight: 400;
        line-height: 28px;
        letter-spacing: -0.08px;
    }

    .not-found__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 34px;
    }

    .not-found__actions a {
        display: inline-flex;
        height: 44px;
        align-items: center;
        justify-content: center;
        border: 1px solid #262b33;
        padding: 0 18px;
        font-family: var(--font-body);
        font-size: 15px;
        font-weight: 600;
        letter-spacing: -0.05px;
        transition:
            border-color 160ms ease,
            background-color 160ms ease,
            color 160ms ease;
    }

    .not-found__primary {
        background: #05070a;
        color: #f5f7fa;
    }

    .not-found__actions a:hover,
    .not-found__actions a:focus-visible {
        border-color: #3a414c;
        background: #0a0c0f;
        color: #ffffff;
        outline: none;
    }

    .not-found__trace {
        border: 1px solid #262b33;
        background: #07090c;
        box-shadow:
            inset 0 1px 0 rgb(255 255 255 / 3%),
            inset 0 -1px 0 rgb(255 255 255 / 2%);
    }

    .not-found__trace-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #262b33;
        padding: 18px 20px;
        color: #8c94a1;
        font-size: 11px;
        line-height: normal;
    }

    .not-found__trace-header p {
        margin: 0;
    }

    .not-found__trace-header span {
        color: #d95a5a;
    }

    .not-found__trace-lines {
        display: grid;
        gap: 12px;
        padding: 22px 20px 24px;
        color: #c8d0dc;
        font-size: 12px;
        line-height: 21px;
        text-transform: none;
    }

    .not-found__trace-lines p {
        display: grid;
        grid-template-columns: 74px minmax(0, 1fr);
        gap: 12px;
        margin: 0;
    }

    .not-found__trace-lines span {
        color: #66d9b2;
    }

    .not-found__bar-layer {
        position: absolute;
        z-index: 0;
        top: 0;
        bottom: 0;
        left: 0;
        width: var(--not-found-rail-width);
        pointer-events: none;
    }

    .not-found__bar {
        position: sticky;
        top: 0;
        display: flex;
        width: var(--not-found-rail-width);
        height: 720px;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        overflow: clip;
        background: repeating-linear-gradient(
            135deg,
            #ffffff 0,
            #ffffff 2.2167px,
            transparent 2.2167px,
            transparent 6.807px
        );
        opacity: 0.14;
    }

    @media (max-width: 1180px) {
        .not-found__bar-layer {
            display: none;
        }

        .not-found__card {
            grid-template-columns: minmax(0, 1fr);
            gap: 48px;
            padding: 64px;
        }

        .not-found__trace {
            max-width: 520px;
        }
    }

    @media (max-width: 900px) {
        .not-found__hero-section {
            padding-top: 24px;
        }

        .not-found__content-section {
            padding-top: 48px;
            padding-bottom: 96px;
        }

        .not-found__hero {
            padding-top: 56px;
        }

        .not-found__hero h1 {
            font-size: 38px;
            line-height: 46px;
            letter-spacing: -0.4px;
        }

        .not-found__status {
            font-size: 26px;
            line-height: 34px;
        }

        .not-found__card {
            padding: 48px;
        }
    }

    @media (max-width: 640px) {
        .not-found__hero-section {
            padding-top: 16px;
        }

        .not-found__content-section {
            padding-top: 40px;
            padding-bottom: 72px;
        }

        .not-found__hero {
            padding-top: 48px;
        }

        .not-found__hero h1 {
            font-size: 34px;
            line-height: 40px;
            gap: 12px;
        }

        .not-found__card {
            padding: 32px 24px 40px;
        }

        .not-found__copy > p:not(.not-found__kicker, .not-found__status) {
            font-size: 16px;
            line-height: 26px;
        }

        .not-found__actions {
            flex-direction: column;
        }

        .not-found__actions a {
            width: 100%;
        }

        .not-found__trace-lines p {
            grid-template-columns: 64px minmax(0, 1fr);
        }
    }
</style>
