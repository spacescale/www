---
import { getCollection, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";

export const getStaticPaths = async () => {
    const posts = await getCollection("engineering");

    return posts.map((post) => ({
        params: { slug: post.id.replace(/\.(md|mdx)$/, "") },
        props: { post },
    }));
};

const { post } = Astro.props;
const { Content } = await render(post);
const coverImage = `/assets/engineering/covers/${post.data.cardVisual}.png`;
---

<SiteLayout title={`${post.data.title} | SpaceScale`} description={post.data.description}>
    <main class="engineering-article">
        <article class="engineering-article__shell">
            <a class="engineering-article__back" href="/engineering">
                SpaceScale Engineering
            </a>
            <div class="engineering-article__header">
                <p class="engineering-article__eyebrow">Engineering</p>
                <h1>{post.data.title}</h1>
                <p>{post.data.description}</p>
            </div>
            <img class="engineering-article__cover" src={coverImage} alt="" />
            <div class="engineering-article__body">
                <Content />
            </div>
        </article>
    </main>
</SiteLayout>

<style>
    .engineering-article {
        min-height: 100vh;
        padding: 96px var(--site-padding-x) 128px;
        background: var(--color-bg-primary);
        color: #f5f7fa;
    }

    .engineering-article__shell {
        width: 100%;
        max-width: 960px;
        margin: 0 auto;
    }

    .engineering-article__back {
        display: inline-flex;
        margin-bottom: 64px;
        color: #8c94a1;
        font-family: var(--font-body);
        font-size: 14px;
        line-height: 20px;
        letter-spacing: 0.12em;
        text-decoration: none;
        text-transform: uppercase;
    }

    .engineering-article__back:focus-visible {
        outline: 1px solid #66d9a8;
        outline-offset: 4px;
    }

    .engineering-article__header {
        display: flex;
        max-width: 840px;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 48px;
    }

    .engineering-article__eyebrow,
    .engineering-article__header h1,
    .engineering-article__header p {
        margin: 0;
    }

    .engineering-article__eyebrow {
        color: #66d9a8;
        font-family: var(--font-mono);
        font-size: 14px;
        line-height: 20px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    .engineering-article__header h1 {
        font-family: var(--font-heading);
        font-size: clamp(48px, 8vw, 92px);
        font-weight: 400;
        line-height: 0.98;
        letter-spacing: 0;
    }

    .engineering-article__header p {
        max-width: 760px;
        color: #8c94a1;
        font-family: var(--font-body);
        font-size: 22px;
        line-height: 34px;
    }

    .engineering-article__cover {
        display: block;
        width: 100%;
        aspect-ratio: 1200 / 630;
        object-fit: cover;
        border: 1px solid #262b33;
        background: #040406;
    }

    .engineering-article__body {
        max-width: 760px;
        margin-top: 56px;
        color: #a5adba;
        font-family: var(--font-body);
        font-size: 20px;
        line-height: 34px;
    }

    .engineering-article__body :global(p) {
        margin: 0 0 24px;
    }

    @media (max-width: 640px) {
        .engineering-article {
            padding-top: 64px;
            padding-bottom: 96px;
        }

        .engineering-article__back {
            margin-bottom: 48px;
        }

        .engineering-article__header p,
        .engineering-article__body {
            font-size: 18px;
            line-height: 30px;
        }
    }
</style>
